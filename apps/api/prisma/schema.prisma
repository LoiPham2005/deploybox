// DeployBox — schema dữ liệu. Xem giải thích ở
// docs/implementation/01-data-model-prisma.md

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS (khớp packages/shared/src/enums.ts) ----------

enum TeamRole {
  OWNER
  MEMBER
}

// Vai trò cấp HỆ THỐNG (khác TeamRole — phạm vi team). Thêm SUPERADMIN/SUPPORT sau chỉ 1 dòng.
enum UserRole {
  USER
  ADMIN
}

enum ProjectType {
  STATIC
  BACKEND
  MOBILE
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  DEPLOYING
  RUNNING
  SLEEPING
  FAILED
  STOPPED
  CANCELLED
}

enum DeploymentTrigger {
  MANUAL
  GIT_PUSH
  REDEPLOY
}

enum DomainStatus {
  PENDING_DNS
  VERIFYING
  ACTIVE
  FAILED
}

enum EnvTarget {
  BUILD
  RUNTIME
  BOTH
}

enum Plan {
  FREE
  PRO
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELED
}

// Đơn thanh toán nâng cấp PRO (cổng SePay — chuyển khoản VietQR).
model Payment {
  id            String        @id @default(cuid())
  teamId        String
  team          Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  orderCode     String        @unique // nội dung chuyển khoản duy nhất (vd DBPRO…)
  amount        Int // VND
  months        Int           @default(1)
  status        PaymentStatus @default(PENDING)
  provider      String        @default("sepay")
  providerTxnId String?       @unique // id giao dịch SePay — chống xử lý trùng
  content       String? // nội dung CK thực nhận (để đối soát)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  @@index([teamId])
}

enum ServerType {
  LOCAL
  REMOTE
}

enum ServerStatus {
  UNKNOWN
  ONLINE
  OFFLINE
}

enum DbEngine {
  POSTGRES
  REDIS
}

// ---------- MODELS ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  avatarUrl    String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Telegram: chat_id nhận thông báo deploy (user tự nối qua deep-link).
  // telegramLinkCode = mã tạm sinh khi bấm "Kết nối", khớp với /start <code> để lấy chat_id.
  telegramChatId   String?
  telegramLinkCode String? @unique

  // 2FA: bật = sau khi đúng mật khẩu phải nhập thêm OTP gửi qua email
  twoFactorEnabled Boolean @default(false)

  memberships   TeamMember[]
  apiTokens     ApiToken[]
  projectAccess ProjectMember[]
  sessions      Session[]
  oauthIdentities OAuthIdentity[]
}

// Danh tính OAuth (GitHub/GitLab/Bitbucket) gắn vào tài khoản — 1 user nhiều nhà.
// Token mã hoá at-rest; GitLab/Bitbucket sau này dùng thêm refreshToken/expiresAt.
model OAuthIdentity {
  id              String      @id @default(cuid())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  provider        GitProvider
  providerUserId  String      // id user phía provider (bất biến)
  login           String      // username phía provider (hiển thị)
  accessTokenEnc  String
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

// Phiên đăng nhập (JWT nhúng sid) — để xem "thiết bị đang đăng nhập" + đăng xuất từ xa.
model Session {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime? // đặt = đăng xuất từ xa; guard từ chối token mang sid này

  @@index([userId])
  @@index([lastSeenAt])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan       Plan     @default(FREE)
  // Mốc hết hạn gói PRO. null = không hết hạn (admin comp / đang FREE).
  planExpiresAt  DateTime?
  // Đã gửi nhắc gia hạn cho kỳ hiện tại chưa (reset khi thanh toán mới).
  renewRemindedAt DateTime?
  isPersonal Boolean  @default(false)
  createdAt  DateTime @default(now())

  members  TeamMember[]
  projects Project[]
  servers  Server[]
  payments Payment[]
}

model Server {
  id            String       @id @default(cuid())
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId        String
  name          String
  host          String       @default("localhost")
  port          Int          @default(22)
  username      String       @default("root")
  sshPrivateKey String?      // AES-256-GCM encrypted; null = local
  type          ServerType   @default(LOCAL)
  status        ServerStatus @default(UNKNOWN)
  projects      Project[]
  createdAt     DateTime     @default(now())

  @@index([teamId])
}

model TeamMember {
  id        String   @id @default(cuid())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id             String       @id @default(cuid())
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         String
  name           String
  slug           String
  type           ProjectType  @default(BACKEND)

  // Server để deploy lên (null = dùng server local mặc định của team)
  server         Server?      @relation(fields: [serverId], references: [id])
  serverId       String?

  // Nguồn code
  gitProvider    GitProvider?
  gitRepoUrl     String?
  gitBranch      String       @default("main")
  rootDir        String       @default(".")
  gitToken       String?      // PAT/access token cho private repo (mã hoá at-rest)
  autoDeploy     Boolean      @default(true)
  webhookSecret  String? // secret HMAC xác thực webhook git (mã hoá at-rest)

  // Cấu hình build/run
  installCommand String?
  buildCommand   String?
  startCommand   String?
  outputDir      String?

  // Hooks (BACKEND): lệnh chạy TRƯỚC khi start app (vd "npx prisma migrate deploy")
  // và SAU khi app đã sống (vd warmup). Null = bỏ qua.
  preDeployCommand  String?
  postDeployCommand String?
  internalPort   Int          @default(3000)
  buildImage     String?
  artifactPath   String?

  // Cách chạy BACKEND: true = build Docker (cần Dockerfile); false = chạy node thẳng trên máy
  useDocker      Boolean      @default(false)

  // Preview deploy theo Pull Request
  previewEnabled  Boolean     @default(false) // parent: bật tạo preview cho mỗi PR
  isPreview       Boolean     @default(false) // true = row này là 1 preview PR (ẩn khỏi dashboard)
  prNumber        Int?                         // số PR mà preview này phục vụ (chỉ preview)
  parent          Project?    @relation("ProjectPreviews", fields: [parentProjectId], references: [id], onDelete: Cascade)
  parentProjectId String?
  previews        Project[]   @relation("ProjectPreviews")

  // Biến env app CẦN (AI đọc từ repo — .env.example/config). Dùng cảnh báo thiếu env trước deploy.
  requiredEnvKeys String[]    @default([])

  // Vận hành / quota
  sleepEnabled   Boolean      @default(false)
  memoryMb       Int          @default(512)
  cpuLimit       Float        @default(0.5)
  notifyUrl      String?      // Webhook URL nhận POST khi build thất bại

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  deployments    Deployment[]
  domains        Domain[]
  envVars        EnvVar[]
  webhookEvents  WebhookEvent[]
  members        ProjectMember[]
  cronJobs       CronJob[]
  databases      ManagedDatabase[]
  metricSamples  MetricSample[]
  incidents      AppIncident[]

  @@unique([teamId, slug])
  @@index([teamId])
  @@index([parentProjectId])
}

// Database 1-click: Postgres/Redis chạy trong Docker container, connection string
// tự bơm vào env project. Mật khẩu mã hoá at-rest.
model ManagedDatabase {
  id            String   @id @default(cuid())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  engine        DbEngine
  name          String
  containerName String   @unique // deploybox-db-<id>
  hostPort      Int      @unique
  username      String
  passwordEnc   String // mã hoá AES-256-GCM
  dbName        String
  envKey        String // env đã bơm (DATABASE_URL / REDIS_URL)
  status        String   @default("running")
  createdAt     DateTime @default(now())

  @@index([projectId])
}

// Lịch chạy lệnh định kỳ cho app (như cron của Railway/Render).
// Chạy lệnh trong thư mục app (host-run) hoặc `docker exec` (Docker mode).
model CronJob {
  id         String    @id @default(cuid())
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  name       String
  schedule   String    // cron 5 trường: "0 3 * * *" (giờ server)
  command    String    // lệnh chạy trong thư mục app
  enabled    Boolean   @default(true)
  lastRunAt  DateTime?
  lastStatus String?   // "success" | "failed"
  lastOutput String?   // đuôi output (giới hạn 4KB)
  createdAt  DateTime  @default(now())

  @@index([projectId])
}

// Quyền xem/dùng project ở cấp THÀNH VIÊN (giống collaborator GitHub).
// OWNER của team luôn thấy mọi project. MEMBER chỉ thấy project có bản ghi này.
model ProjectMember {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

model Deployment {
  id           String            @id @default(cuid())
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  status       DeploymentStatus  @default(QUEUED)
  trigger      DeploymentTrigger @default(MANUAL)

  commitSha    String?
  commitMsg    String?
  imageTag     String?
  containerId  String?
  staticPath   String?
  logKey       String?
  errorMessage String?

  // Kết quả AI "bác sĩ lỗi deploy" (nguyên nhân + cách sửa). Null = chưa chẩn đoán.
  aiDiagnosis  Json?

  queuedAt   DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  createdBy  String?

  @@index([projectId, queuedAt(sort: Desc)])
  @@index([status])
}

model Domain {
  id          String       @id @default(cuid())
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  hostname    String       @unique
  isPrimary   Boolean      @default(false)
  isManaged   Boolean      @default(false)
  status      DomainStatus @default(PENDING_DNS)
  verifyToken String?
  createdAt   DateTime     @default(now())

  @@index([projectId])
}

model EnvVar {
  id        String    @id @default(cuid())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  key       String
  value     String
  isSecret  Boolean   @default(false)
  target    EnvTarget @default(RUNTIME)

  @@unique([projectId, key])
}

model WebhookEvent {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  source    String   // "github" | "gitlab" | "bitbucket"
  branch    String?
  commitSha String?
  status    String   // "deployed" | "skipped" | "rejected"
  reason    String?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt(sort: Desc)])
}

model ApiToken {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// Cờ bật/tắt tính năng toàn hệ thống (admin quản). Seed từ danh sách biết trước trong code.
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(true)
  label       String
  description String?
  updatedAt   DateTime @updatedAt
}

// Cấu hình dạng key/value do admin chỉnh (vd ai_provider, ai_model). Linh hoạt, thêm sau dễ.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Mã OTP gửi qua email (xác thực đăng ký / quên mật khẩu).
// Không lưu mã thô — chỉ sha256. Đăng ký: user CHỈ được tạo sau khi verify OTP,
// thông tin đăng ký (name + passwordHash) giữ tạm trong payload.
// 📈 Mẫu CPU/RAM mỗi phút của app BACKEND đang chạy (C1) — giữ 7 ngày, tự dọn.
model MetricSample {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  at        DateTime @default(now())
  cpuPct    Float?   // % CPU (docker: chính xác; host-run: xấp xỉ qua ps)
  memMb     Float    // RAM đang dùng (MB)

  @@index([projectId, at])
}

// 🔴 Sự cố app không trả lời HTTP (C2) — mở khi phát hiện DOWN, đóng khi hồi phục.
model AppIncident {
  id        String    @id @default(cuid())
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  startedAt DateTime  @default(now())
  endedAt   DateTime? // null = đang down
  reason    String?   // lỗi lần check cuối (timeout / HTTP 5xx…)

  @@index([projectId, startedAt(sort: Desc)])
}

// 📝 Nhật ký hoạt động: ai làm gì lúc nào (mọi request ghi/sửa/xoá có đăng nhập).
// KHÔNG lưu body request (env value, mật khẩu… không được lọt vào log).
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  method    String   // POST/PATCH/PUT/DELETE
  path      String   // đường dẫn cụ thể (đã cắt query string)
  action    String   // nhãn tiếng Việt suy từ route (vd "Deploy project")
  status    Int      // HTTP status trả về
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  purpose   String   // "register" | "reset" | "login" (2FA)
  codeHash  String
  payload   String?  // register: JSON { name, passwordHash }
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, purpose])
  @@index([expiresAt])
}

// 📚 "Trí nhớ sửa lỗi": lỗi đã gặp + cách sửa ĐÃ CHỨNG MINH hiệu quả (fail → fix → deploy OK).
// Lỗi mới trùng chữ ký → trả lời từ đây, không tốn AI.
model FixMemory {
  id          String   @id @default(cuid())
  projectId   String?  // ưu tiên khớp cùng project; null = dùng chung
  errorSig    String   // chữ ký lỗi đã chuẩn hoá (bỏ số/id/đường dẫn)
  cause       String
  fix         String
  configField String?
  configValue String?
  verified    Boolean  @default(false) // fix này đã dẫn tới deploy thành công
  hits        Int      @default(0) // số lần được dùng lại
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([errorSig])
}

// 💰 Nhật ký gọi AI (đếm token để tính chi phí theo tính năng/model)
model AiUsage {
  id           String   @id @default(cuid())
  feature      String   // diagnosis | auto_diagnosis | analyze | summary | answer | dockerfile | report
  provider     String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([feature])
}
