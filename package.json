{
  "name": "deploybox",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build:shared": "pnpm --filter @deploybox/shared build",
    "build": "pnpm build:shared && pnpm --filter @deploybox/api build && pnpm --filter @deploybox/web build",
    "dev": "pnpm build:shared && pnpm --parallel --filter @deploybox/api --filter @deploybox/web dev",
    "dev:api": "pnpm --filter @deploybox/api start:dev",
    "dev:web": "pnpm --filter @deploybox/web dev",
    "typecheck": "pnpm build:shared && pnpm --filter @deploybox/api typecheck && pnpm --filter @deploybox/web typecheck",
    "db:generate": "pnpm --filter @deploybox/api prisma generate",
    "db:migrate": "pnpm --filter @deploybox/api prisma migrate dev",
    "db:seed": "pnpm --filter @deploybox/api db:seed",
    "db:studio": "pnpm --filter @deploybox/api prisma studio",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "caddy": "caddy run --config caddy/init.caddyfile --adapter caddyfile"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "esbuild"]
  }
}
